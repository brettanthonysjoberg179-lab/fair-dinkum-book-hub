{
  "name": "fair-dinkum-book-hub",
  "version": "1.0.0",
  "description": "Professional eBook building platform with automated multi-format publishing via GitHub Actions",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:html && npm run build:pdf && npm run build:epub",
    "build:html": "node scripts/build-html.js",
    "build:pdf": "node scripts/build-pdf.js",
    "build:epub": "python scripts/build_epub.py",
    "validate:markdown": "markdownlint 'content/**/*.md'",
    "validate:frontmatter": "node scripts/validate-frontmatter.js",
    "lint:content": "eslint scripts/**/*.js && prettier --check 'content/**/*.md'",
    "optimize": "node scripts/optimize.js",
    "dev": "nodemon --watch content --watch scripts --exec 'npm run build:html'",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean && npm run validate:frontmatter",
    "postbuild": "npm run optimize",
    "test": "npm run validate:markdown && npm run validate:frontmatter",
    "prepare": "npm run test"
  },
  "keywords": [
    "ebook",
    "publishing",
    "markdown",
    "pdf",
    "epub",
    "html",
    "automation"
  ],
  "author": "Brett Anthony Sjoberg",
  "license": "MIT",
  "dependencies": {
    "ebooklib": "^0.18.0",
    "js-yaml": "^4.1.0",
    "marked": "^9.1.2",
    "puppeteer": "^21.1.1",
    "yaml": "^2.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "eslint": "^8.44.0",
    "jest": "^29.5.0",
    "markdownlint": "^0.29.0",
    "markdownlint-cli": "^0.34.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0"
  },
  "optionalDependencies": {
    "calibre": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brettanthonysjoberg179-lab/fair-dinkum-book-hub.git"
  },
  "bugs": {
    "url": "https://github.com/brettanthonysjoberg179-lab/fair-dinkum-book-hub/issues"
  },
  "homepage": "https://github.com/brettanthonysjoberg179-lab/fair-dinkum-book-hub#readme"
}
